---
import Layout from '../layouts/Layout.astro';
import BlogList from '../components/BlogList.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const categories = [
  ...new Set(allPosts.map((post) => post.data.category).filter(Boolean)),
];
---

<Layout title='Blog'>
  <header class='mt-16 mb-12'>
    <h1 class='font-handwriting text-lead-100 text-4xl font-medium tracking-tight'>
      <span class='flex items-center gap-3'>
        <Icon
          name='streamline-pixel:content-files-typing-machine'
          class='size-10'
        />
        ရောက်တတ်ရာရာ
      </span>
    </h1>
    <p class='text-lead-500 mt-4 max-w-md text-sm leading-relaxed'>
      A collection of random notes, half-baked thoughts, and personal reflections.
    </p>

  </header>

  <section>
    <BlogList />
  </section>
</Layout>
