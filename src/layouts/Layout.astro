---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
}

const { title } = Astro.props;

const SITE_NAME = 'Khant Zaw Phyo';
const SITE_URL = 'https://khantzawphyo.dev';
const DESCRIPTION =
  'Khant Zaw Phyo — Computer Science and Engineering (CSE) undergraduate at MIIT, Mandalay. Aspiring web developer diving deep into the JavaScript ecosystem — React, TypeScript, and beyond.';

const pageTitle = title
  ? `${SITE_NAME} — ${title}`
  : `${SITE_NAME} — Portfolio`;
const canonicalURL = new URL(Astro.url.pathname, SITE_URL);
---

<!doctype html>
<html lang='en'>
  <head>
    <BaseHead
      title={pageTitle}
      description={DESCRIPTION}
      url={SITE_URL}
      canonicalURL={canonicalURL}
    />
  </head>
  <body
    class='bg-lead-800 text-lead-100 font-sans antialiased transition-colors duration-300'
  >
    <div class='grain-overlay pointer-events-none' aria-hidden='true'></div>

    <main class='mx-auto max-w-xl px-6 pt-16'>
      <Header />
      <slot />
      <Footer />
    </main>
  </body>
</html>
