---
import Layout from '../layouts/Layout.astro';
import GoTop from '../components/GoTop.astro';
import BlogList from '../components/BlogList.astro';
import { projects, education, toolkit } from '../data/data';
import Greeting from '../components/Greeting.astro';
import { Icon } from 'astro-icon/components';

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
};
---

<Layout title='Portfolio'>
  <section class='mt-4'>
    <h1
      class='font-display mb-2 text-5xl leading-[1.2] font-medium tracking-tight'
    >
      <span class='flex items-start gap-2'>
        <Icon
          name='streamline-pixel:music-headphones-human'
          class='size-10.5'
        />
        <Greeting />
      </span>
      <span class='text-lead-100 block'>I'm Khant Zaw Phyo.</span>
    </h1>
    <p class='text-lead-400 leading-relaxed'>
      I'm a CS student majoring in Computer Science and Engineering (CSE) at
      <a
        href='https://miitmdy.edu.mm'
        class='decoration-lead-100 hover:text-accent hover:underline'>MIIT</a
      >, Mandalay. I also go by the name
      <span class='text-accent font-medium'>@wills365</span> online. I'm interested
      in AI, Web Development, and building things that are both functional and intuitive.
    </p>
  </section>

  <section class='mt-20'>
    <div class='mb-6 flex items-center justify-between'>
      <h2 class='text-lead-100 font-display text-2xl'>Selected Projects</h2>
      <a
        href='/projects'
        class='text-lead-500 hover:text-accent inline-flex items-center gap-1 text-xs transition-colors'
        >View all <Icon name='f7:arrow-right' />
      </a>
    </div>
    <div class='space-y-8'>
      {
        projects.slice(0, 3).map((project) => (
          <a href={project.github} class='group block'>
            <div class='mb-1 flex flex-col items-start justify-between gap-2 sm:flex-row sm:items-baseline sm:gap-0'>
              <h3 class='text-lead-200 group-hover:text-accent inline-flex items-center font-medium transition-colors'>
                {project.title}
                <span class='overflow-hidden'>
                  <Icon
                    name='f7:arrow-up-right'
                    class='text-lead-200 ms-1 size-3 -translate-x-2 opacity-0 transition-all duration-300 ease-in-out group-hover:translate-x-0 group-hover:opacity-100'
                  />
                </span>
              </h3>
              <div class='flex flex-wrap gap-2'>
                {project.tags.map((tag) => (
                  <span class='border-lead-500 text-lead-500 rounded-full border px-1.5 py-0.5 text-[10px] tracking-wider uppercase'>
                    {tag}
                  </span>
                ))}
              </div>
            </div>
            <p class='text-lead-500 mt-2 text-sm leading-snug'>
              {project.description}
            </p>
          </a>
        ))
      }
    </div>
  </section>

  <section class='mt-20'>
    <div class='mb-6'>
      <h2 class='text-lead-100 font-display text-3xl'>Education</h2>
    </div>
    <div class='space-y-6'>
      {
        education.map((edu) => (
          <div class='flex flex-col justify-between gap-1 sm:flex-row sm:items-baseline sm:gap-4'>
            <div>
              <a
                href={edu.link}
                target='_blank'
                rel='noopener noreferrer'
                class='group inline-block'
              >
                <h3 class='text-lead-200 group-hover:text-accent inline-flex items-center font-medium transition-colors'>
                  {edu.school}
                  <span class='overflow-hidden'>
                    <svg class='text-lead-200 ms-1 size-3 -translate-x-2 opacity-0 transition-all duration-300 ease-in-out group-hover:translate-x-0 group-hover:opacity-100'>
                      <use href='#ai:local:stroke-arrow-upRight' />
                    </svg>
                  </span>
                </h3>
              </a>
              <p class='text-lead-500 text-sm'>{edu.degree}</p>
            </div>
            <span class='text-lead-500 text-xs whitespace-nowrap tabular-nums'>
              {edu.period}
            </span>
          </div>
        ))
      }
    </div>
  </section>

  <section class='mt-20'>
    <div class='mb-6'>
      <h2 class='text-lead-100 font-display text-3xl'>My Toolkit</h2>
    </div>
    <div class='space-y-8'>
      {
        toolkit.map((group) => (
          <div>
            <h3 class='text-lead-500 mb-4 text-xs font-medium tracking-wider uppercase'>
              {group.category}
            </h3>
            <div class='grid grid-cols-2 gap-3 sm:grid-cols-3'>
              {group.items.map((item) => (
                <div class='border-lead-800 bg-lead-900/30 hover:border-accent/50 flex cursor-pointer items-center gap-3 rounded-xl border p-3 transition-colors'>
                  <img
                    src={item.logo}
                    alt={item.name}
                    class='size-6 transition-all'
                  />
                  <span class='text-lead-200 text-sm'>{item.name}</span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class='mt-20 mb-20'>
    <div class='mb-6 flex items-center justify-between'>
      <h2 class='text-lead-100 font-display text-3xl'>Writings</h2>
      <a
        href='/blog'
        class='text-lead-500 hover:text-accent inline-flex items-center gap-1 text-xs transition-colors'
        >Read blog <Icon name='f7:arrow-right' />
      </a>
    </div>
    <BlogList limit={4} />
  </section>

  <GoTop />
</Layout>
