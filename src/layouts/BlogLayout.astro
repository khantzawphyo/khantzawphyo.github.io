---
import Layout from './Layout.astro';
import { Icon } from 'astro-icon/components';
import GoTop from '../components/GoTop.astro';

const { post, prev, next } = Astro.props;
const { tags = [] } = post.data; // <-- Safely extract tags array

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<Layout title={post.data.title}>
  <article class='my-6 md:my-12'>
    <header class='border-lead-600/20 relative mb-12'>
      <div
        class='mb-4 flex items-center gap-3 text-sm tracking-wider select-none'
      >
        <a
          href='/blog'
          class='text-lead-500 hover:text-accent flex items-center gap-1 font-medium transition-colors'
          aria-label='Back to blog'
        >
          <Icon name='f7:arrowshape-turn-up-left-fill' class='size-3' />
          <span>Back to blog</span>
        </a>
      </div>

      <h1
        class='text-lead-100 font-serif text-3xl font-extrabold tracking-tight sm:text-4xl md:text-5xl md:leading-[1.15]'
      >
        {post.data.title}
      </h1>

      <div
        class='border-lead-600/10 text-lead-400 mt-6 flex items-center justify-between border-t border-dashed pt-4 text-xs select-none'
      >
        <div class='flex items-center gap-3 font-medium tabular-nums'>
          <div class='flex items-center gap-1.5'>
            <Icon name='lucide:calendar' class='text-lead-500 size-3.5' />
            <time class='text-lead-300'>{formattedDate}</time>
          </div>

          {
            post.data.category && (
              <>
                <span
                  class='text-lead-600 size-1 rounded-full bg-current'
                  aria-hidden='true'
                />
                <span class='text-accent text-[11px] font-semibold tracking-wider uppercase'>
                  {post.data.category}
                </span>
              </>
            )
          }
        </div>

        <button
          id='copy-link'
          class='text-lead-500 hover:text-accent flex cursor-pointer items-center gap-1 transition-colors'
        >
          <Icon name='lucide:link' class='size-3' />
          <span id='copy-text'>Share article</span>
        </button>
      </div>
    </header>

    <div class='prose-custom'>
      <slot />
    </div>

    {
      tags.length > 0 && (
        <div class='my-8 flex flex-wrap items-center gap-2 text-xs select-none'>
          <span class='text-lead-500 font-mono text-[11px] tracking-wider uppercase'>
            Tags:
          </span>
          {tags.map((tag) => (
            <span class='text-lead-400 border-lead-700/40 bg-lead-900/20 hover:border-lead-600 hover:text-lead-200 rounded-md border px-2 py-0.5 font-mono text-[13px] lowercase transition-colors'>
              #{tag}
            </span>
          ))}
        </div>
      )
    }
  </article>

  <div class='pointer-events-none text-center select-none'>
    <span class='text-lead-600 font-serif text-lg tracking-[0.5em]'>***</span>
  </div>

  <footer class='border-lead-600/30 mt-10 mb-20 border-t pt-6'>
    <div class='grid grid-cols-1 gap-8 sm:grid-cols-2'>
      {
        prev ? (
          <a href={`/blog/${prev.id}`} class='group flex flex-col gap-1'>
            <span class='text-lead-600 group-hover:text-accent flex items-center gap-1.5 tracking-widest transition-colors'>
              <Icon name='f7:arrowshape-turn-up-left-fill' class='size-3.5' />
              Prev
            </span>
            <span class='text-lead-200 group-hover:text-lead-100 text-md font-serif transition-colors'>
              {prev.data.title}
            </span>
          </a>
        ) : (
          <div />
        )
      }
      {
        next ? (
          <a
            href={`/blog/${next.id}`}
            class='group flex flex-col gap-1 text-right'
          >
            <span class='text-lead-600 group-hover:text-accent flex items-center justify-end gap-1.5 tracking-widest transition-colors'>
              Next
              <Icon name='f7:arrowshape-turn-up-right-fill' class='size-3.5' />
            </span>
            <span class='text-lead-200 group-hover:text-lead-100 text-md font-serif transition-colors'>
              {next.data.title}
            </span>
          </a>
        ) : (
          <div />
        )
      }
    </div>
  </footer>

  <GoTop />
</Layout>

<script>
  const copyBtn = document.getElementById('copy-link');
  const copyText = document.getElementById('copy-text');
  copyBtn?.addEventListener('click', () => {
    navigator.clipboard.writeText(window.location.href);
    if (copyText) {
      const originalText = copyText.textContent;
      copyText.textContent = 'Copied!';
      copyBtn.classList.add('text-accent');
      setTimeout(() => {
        copyText.textContent = originalText;
        copyBtn.classList.remove('text-accent');
      }, 2000);
    }
  });
</script>
