---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title='404: Not Found'>
  <head slot='head'>
    <meta http-equiv='refresh' content='5;url=/' />
  </head>

  <main
    class='flex min-h-[70vh] flex-col items-center justify-center text-center'
  >
    <div class='mb-8'>
      <Icon name='streamline-pixel:coding-apps-websites-404-error' class='size-14' />
    </div>

    <h1
      class='font-display text-lead-100 text-5xl font-medium tracking-tighter'
    >
      Page not found
    </h1>

    <p class='text-lead-500 mt-4 max-w-xs font-sans text-sm leading-relaxed'>
      The coordinates you entered lead to a void. Returning you to the home page
      in 5 seconds.
    </p>

    <div class='mt-10'>
      <a
        href='/'
        class='text-lead-400 hover:text-accent font-mono text-xs tracking-[0.2em] uppercase transition-colors'
      >
        [ click to return immediately ]
      </a>
    </div>
  </main>
</Layout>
