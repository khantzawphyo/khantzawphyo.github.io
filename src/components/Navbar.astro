---
import { Icon } from 'astro-icon/components';

const navLinks = [
  { name: 'Home', link: '/' },
  { name: 'Blog', link: '/blog' },
  { name: 'Projects', link: '/projects' },
  { name: 'Resume', link: '/resume' },
];
---

<nav class='mb-14 flex items-center justify-between'>
  <a
    href='/'
    aria-label='Home'
    class='group relative inline-flex size-8 items-center justify-center'
  >
    <div
      class='absolute inset-0 rounded-full bg-[linear-gradient(180deg,#ff3100_0%,#ff4f17_40%,#212121_100%)] opacity-80 transition-all duration-200 ease-in-out group-hover:opacity-0'
    >
    </div>
    <img
      src='/kzp_avatar.png'
      alt='Khant Zaw Phyo'
      class='absolute w-10 scale-100 rounded-full object-cover opacity-0 brightness-0 invert transition-all duration-200 ease-out group-hover:scale-[1.2] group-hover:opacity-100 group-hover:brightness-100 group-hover:invert-0'
    />
  </a>

  <div class='flex items-center gap-6'>
    {
      navLinks.map((navLink) => (
        <a
          href={navLink.link}
          class='group text-lead-500 hover:text-lead-100 relative inline-flex items-center text-sm transition-colors'
        >
          <span class='group-hover:underline'>{navLink.name}</span>

          {navLink.name === 'Resume' && (
            <span class='pointer-events-none absolute left-full ml-0.5 overflow-hidden'>
              <Icon
                name='f7:arrow-up-right'
                class='size-3 -translate-x-full opacity-0 transition-all duration-300 ease-in-out group-hover:translate-x-0 group-hover:opacity-100'
              />
            </span>
          )}
        </a>
      ))
    }
  </div>
</nav>
