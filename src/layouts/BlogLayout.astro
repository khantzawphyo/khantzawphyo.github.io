---
import Layout from './Layout.astro';
import { Icon } from 'astro-icon/components';
import GoTop from '../components/GoTop.astro';

const { post, prev, next } = Astro.props;

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<Layout title={post.data.title}>
  <article class='mt-12 mb-24'>
    <nav class='mb-12'>
      <div class='flex items-center justify-between'>
        <a
          href='/blog'
          class='group border-lead-800 bg-lead-700/20 text-lead-300 hover:border-accent hover:text-accent flex size-10 items-center justify-center rounded-full border transition-all duration-300'
          aria-label='Back to blog'
        >
          <Icon name='f7:arrow-uturn-left' class='size-4' />
        </a>

        <button
          id='copy-link'
          class='border-lead-800 bg-lead-700/20 text-lead-300 hover:border-accent hover:text-accent cursor-pointer rounded-full border px-4 py-2 text-sm font-medium transition-all duration-300'
        >
          <span id='copy-text'>Copy link</span>
        </button>
      </div>
    </nav>

    <header class='border-lead-600/30 mb-12 border-b pb-4'>
      <h1
        class='font-display text-lead-100 text-4xl leading-tight font-medium tracking-tight sm:text-5xl'
      >
        {post.data.title}
      </h1>

      <div class='mt-4 flex items-center gap-2.5'>
        <time
          class='text-lead-500 text-sm tracking-widest uppercase tabular-nums'
        >
          {formattedDate}
        </time>
        {
          post.data.category && (
            <>
              <span
                class='text-lead-500 size-1 rounded-full bg-current'
                aria-hidden='true'
              />
              <span class='text-accent text-sm capitalize'>
                {post.data.category}
              </span>
            </>
          )
        }
      </div>
    </header>

    <div
      class='prose prose-invert prose-img:rounded-md prose-img:w-full prose-img:mx-auto prose-p:text-lead-300 prose-p:leading-[1.8] prose-p:text-[17px] prose-hr:border-lead-600/30 prose-headings:font-semibold prose-headings:text-lead-100 prose-strong:text-lead-100 prose-strong:font-bold prose-blockquote:border-accent prose-blockquote:italic prose-blockquote:text-lead-400 prose-a:font-sans prose-a:text-accent prose-a:no-underline prose-a:border-b prose-a:border-accent/30 prose-a:transition-all prose-a:duration-200 hover:prose-a:border-accent hover:prose-a:text-accent/80 prose-table:font-sans prose-table:text-lead-300 prose-table:text-sm prose-th:font-sans prose-th:border-lead-600 prose-th:border-b prose-th:pb-2 prose-th:text-left prose-th:font-medium prose-th:text-accent prose-td:border-lead-600/30 prose-td:border-b prose-td:py-2 max-w-none font-serif'
    >
      <slot />
    </div>
  </article>

  <div class='mt-20 text-center'>
    <span class='text-lead-600 font-serif text-lg tracking-[0.5em]'>***</span>
  </div>
  <footer class='border-lead-600/30 mt-24 mb-20 border-t pt-6'>
    <div class='grid grid-cols-1 gap-8 sm:grid-cols-2'>
      {
        prev ? (
          <a href={`/blog/${prev.id}`} class='group flex flex-col gap-1'>
            <span class='text-lead-600 group-hover:text-accent text-sm tracking-widest transition-colors'>
              Prev
            </span>
            <span class='text-lead-200 group-hover:text-lead-100 font-serif text-lg transition-colors'>
              {prev.data.title}
            </span>
          </a>
        ) : (
          <div />
        )
      }

      {
        next ? (
          <a
            href={`/blog/${next.id}`}
            class='group flex flex-col gap-2 text-right'
          >
            <span class='text-lead-600 group-hover:text-accent text-sm tracking-widest transition-colors'>
              Next
            </span>
            <span class='text-lead-200 group-hover:text-lead-100 font-serif text-lg transition-colors'>
              {next.data.title}
            </span>
          </a>
        ) : (
          <div />
        )
      }
    </div>
  </footer>
  <GoTop />
</Layout>

<script>
  const copyBtn = document.getElementById('copy-link');
  const copyText = document.getElementById('copy-text');

  copyBtn?.addEventListener('click', () => {
    navigator.clipboard.writeText(window.location.href);
    if (copyText) {
      const originalText = copyText.textContent;
      copyText.textContent = 'Copied!';
      copyBtn.classList.add('border-accent', 'text-accent');

      setTimeout(() => {
        copyText.textContent = originalText;
        copyBtn.classList.remove('border-accent', 'text-accent');
      }, 2000);
    }
  });
</script>
